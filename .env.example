# PostgreSQL is required for production and production-like local testing.
# Do not use SQLite/file URLs for this client runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/nord_basilico?schema=public"

# Restaurant identity per deployment
RESTAURANT_NAME="Basilico"
RESTAURANT_SLUG="basilico"
RESTAURANT_DOMAIN="menu.basilico.example"
FALLBACK_DOMAIN="basilico.nordapp.se"
DOMAIN_MODE="custom-subdomain"
VERCEL_PROJECT_NAME="nord-basilico"

POSTGRES_DATABASE_NAME="nord_basilico"
# Optional administrative/provisioning URLs.
# POSTGRES_ADMIN_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"
# DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/nord_basilico?schema=public"
#
# Migration notes:
# - use DATABASE_URL for runtime and Prisma migrations
# - use DIRECT_URL for Prisma migrate / administrative connections when needed
# - each deployment must point to its own PostgreSQL database
# - do not reuse one PostgreSQL database across restaurants

# Internal auth bootstrap users for the database-backed auth system.
# These are inserted only if the usernames do not already exist.
AUTH_BOOTSTRAP_ADMIN_USERNAME="admin"
AUTH_BOOTSTRAP_ADMIN_PASSWORD="replace-with-strong-admin-password"
AUTH_BOOTSTRAP_ADMIN_DISPLAY_NAME="Basilico Admin"
AUTH_BOOTSTRAP_ADMIN_EMAIL="admin@example.com"

AUTH_BOOTSTRAP_KITCHEN_USERNAME="kitchen"
AUTH_BOOTSTRAP_KITCHEN_PASSWORD="replace-with-strong-kitchen-password"
AUTH_BOOTSTRAP_KITCHEN_DISPLAY_NAME="Basilico Kitchen"

# Auth/session
# Required in staging/production. The runtime rejects an empty pepper outside local.
AUTH_PASSWORD_PEPPER=""
SESSION_COOKIE_NAME="basilico_session"
SESSION_TTL_HOURS="168"

# Uploads
# Current runtime only supports local upload storage for admin-managed general assets.
UPLOADS_BASE_DIR="public/restaurants/basilico/dishes/uploads"
UPLOADS_PUBLIC_BASE_PATH="/restaurants/basilico/dishes/uploads"
UPLOADS_MAX_IMAGE_BYTES="5242880"

# Internal runtime labeling
# Use local, staging, or production.
INTERNAL_ENVIRONMENT_LABEL="local"
