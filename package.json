{
  "name": "basilico-nord-menu",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test:interactions": "node ./scripts/trace-menu-interactions.mjs",
    "prisma:validate": "node ./node_modules/prisma/build/index.js validate --schema ./prisma/schema.prisma",
    "prisma:migrate:deploy": "node ./node_modules/prisma/build/index.js migrate deploy --schema ./prisma/schema.prisma",
    "seed:menu": "node ./scripts/seed-basilico-menu.mjs",
    "provision:db": "node ./scripts/provision-restaurant-database.mjs"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "next": "^16.0.0",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.0",
    "playwright": "^1.59.1",
    "typescript": "^5.0.0"
  }
}
